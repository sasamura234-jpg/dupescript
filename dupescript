-- ゲーム内の音をすべて自動ミュート
-----------------------------------------------------
local function muteAllSounds()
    for _, desc in pairs(game:GetDescendants()) do
        if desc:IsA("Sound") then desc.Volume = 0 end
    end
    game.DescendantAdded:Connect(function(desc)
        if desc:IsA("Sound") then desc.Volume = 0 end
    end)
end
pcall(muteAllSounds)

