-- 共通マクロ関数（裏で実行される動作）
-----------------------------------------------------
local function clickCoords(x, y)
    VIM:SendMouseButtonEvent(x, y, 0, true, game, 1)
    task.wait(0.01)
    VIM:SendMouseButtonEvent(x, y, 0, false, game, 1)
    task.wait(0.02)
end

local function directTypeAndSubmit(targetBox, text)
    targetBox:CaptureFocus()
    task.wait(0.02)
    targetBox.Text = text
    task.wait(0.05)
    targetBox:ReleaseFocus(true)
    VIM:SendKeyEvent(true, Enum.KeyCode.Return, false, game)
    task.wait(0.01)
    VIM:SendKeyEvent(false, Enum.KeyCode.Return, false, game)
end

local function holdPromptForDuration(holdTime)
    local character = Plr.Character
    if not character or not character:FindFirstChild("HumanoidRootPart") then return end
    
    local hrp = character.HumanoidRootPart
    local closestPrompt = nil
    local minDistance = 20
    
    for _, desc in pairs(workspace:GetDescendants()) do
        if desc:IsA("ProximityPrompt") and desc.Enabled then
            local parent = desc.Parent
            if parent and parent:IsA("BasePart") then
                local dist = (hrp.Position - parent.Position).Magnitude
                if dist < minDistance then
                    minDistance = dist
                    closestPrompt = desc
                end
            end
        end
    end
    
    if closestPrompt then
        local keyCode = closestPrompt.KeyboardKeyCode
        VIM:SendKeyEvent(true, keyCode, false, game)
        task.wait(holdTime)
        VIM:SendKeyEvent(false, keyCode, false, game)
        task.wait(0.1)
    end
end

-- メインの自動化マクロ本体
local function runFullProcess()
    if not loopActive then return end
    
    -- 最初のみ画面アクティブ化
    VIM:SendMouseButtonEvent(100, 100, 0, true, game, 1)
    task.wait(0.05)
    VIM:SendMouseButtonEvent(100, 100, 0, false, game, 1)
    task.wait(0.05)
    
    -- 【1回だけ実行するセクション】
    if loopActive then
        local character = Plr.Character
        local hrp = character and character:FindFirstChild("HumanoidRootPart")
        
        -- 1. 指定された座標 (136, 149, -37) にTP
        if hrp then
            hrp.CFrame = CFrame.new(136, 149, -37)
            task.wait(0.3)
        end
        
        -- 2. プロンプトを3秒長押し ➔ 1秒待機 ➔ 3秒長押し
        holdPromptForDuration(3.0)
        task.wait(1.0)
        holdPromptForDuration(3.0)
        task.wait(0.2)
        
        -- 3. (498, 318) に karasima79 を入力
        clickCoords(498, 318)
        task.wait(0.1)
        
        local focusedBox = UIS:GetFocusedTextBox()
        if focusedBox then
            directTypeAndSubmit(focusedBox, "karasima79")
        else
            for _, desc in pairs(PlayerGui:GetDescendants()) do
                if desc:IsA("TextBox") and desc.Visible and desc.Name ~= "TextLabel" then
                    directTypeAndSubmit(desc, "karasima79")
                end
            end
        end
        task.wait(0.4)
    end
    
    -- 【無限ループ】高速タップ繰り返し
    while loopActive do
        for i = 1, 20 do
            if not loopActive then break end
            clickCoords(337, 383)
        end
        task.wait(0.05)
        
        if loopActive then
            clickCoords(1174, 792)
        end
        task.wait(0.1)
    end
end

-----------------------------------------------------
-- 10分間の英語ロード画面を生成する関数
-----------------------------------------------------
local function startLoadingScreen()
    local loadingGui = Instance.new("ScreenGui", PlayerGui)
    loadingGui.Name = "UltraLoading"; loadingGui.DisplayOrder = 999; loadingGui.ResetOnSpawn = false

    local bg = Instance.new("Frame", loadingGui)
    bg.Size = UDim2.new(1, 0, 1, 0); bg.BackgroundColor3 = Color3.new(0.02, 0.02, 0.02); bg.BorderSizePixel = 0

    local titleLabel = Instance.new("TextLabel", bg)
    titleLabel.Size = UDim2.new(0, 400, 0, 40); titleLabel.Position = UDim2.new(0.5, -200, 0.4, -20)
    titleLabel.BackgroundTransparency = 1; titleLabel.TextColor3 = Color3.new(1, 1, 1)
    titleLabel.Font = Enum.Font.SourceSansBold; titleLabel.TextSize = 24; titleLabel.Text = "Loading Script Packages..."

    local percentLabel = Instance.new("TextLabel", bg)
    percentLabel.Size = UDim2.new(0, 200, 0, 30); percentLabel.Position = UDim2.new(0.5, -100, 0.4, 20)
    percentLabel.BackgroundTransparency = 1; percentLabel.TextColor3 = Color3.new(0.3, 0.6, 1)
    percentLabel.Font = Enum.Font.Code; percentLabel.TextSize = 20; percentLabel.Text = "0.00 %"

    task.spawn(function()
        local totalDuration = 600
        local startTime = os.clock()
        while true do
            local elapsed = os.clock() - startTime
            if elapsed >= totalDuration then
                percentLabel.Text = "100.00 %"; titleLabel.Text = "Booting Done!"; task.wait(0.5)
                loadingGui:Destroy()
                break
            end
            local progressRatio = math.sqrt(elapsed / totalDuration)
            local currentPercent = progressRatio * 100
            percentLabel.Text = string.format("%.2f %%", currentPercent)
            if currentPercent > 85 then
                titleLabel.Text = "Finalizing core systems (Getting slower)..."
            elseif currentPercent > 50 then
                titleLabel.Text = "Injecting modules into environment..."
            end
            task.wait(0.05)
        end
    end)
end

